# ── AegisLab AI — Environment Variables Template ──
# Copy this file to .env and fill in your actual keys:
#   copy .env.template .env

# Google Gemini API (2 keys for redundancy)
GEMINI_API_KEY_1=your_gemini_key_here
GEMINI_API_KEY_2=your_gemini_key_2_here

# OpenAI GPT-4o (2 keys for redundancy)
OPENAI_API_KEY_1=your_openai_key_here
OPENAI_API_KEY_2=your_openai_key_2_here

# TiDB Cloud (MySQL-compatible) — async driver
TIDB_URL=mysql+aiomysql://user:password@host:4000/test

# Firebase Service Account JSON path
# FIREBASE_CRED_PATH=path/to/your/service-account.json
